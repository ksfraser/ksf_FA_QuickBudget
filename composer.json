{
    "name": "ksfraser/ksf-fa-calendar",
    "description": "FA Calendar Module for FrontAccounting",
    "type": "fa-module",
    "license": "GPL-3.0",
    "require": {
        "php": ">=7.4",
        "ksfraser/ksf-calendar": "*",
        "ksfraser/ksf-calendar-ui": "*",
        "ksfraser/ksf-fa-common": "@dev",
        "ksfraser/exceptions": "*",
        "ksfraser/genericinterface": "*",
        "ksfraser/html": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\": "src/Ksfraser/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "7.4.33"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ksf_Calendar"
        },
        {
            "type": "path",
            "url": "../ksf_Calendar_UI"
        },
        {
            "type": "path",
            "url": "../ksf_FA_Common"
        }
    ]
}
